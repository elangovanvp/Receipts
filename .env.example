# Receipts — environment variables
# Copy to .env.local and fill in your values.

# Required: free Groq API key from https://console.groq.com/keys
GROQ_API_KEY=

# Optional: override the default Groq LLM (llama-3.3-70b-versatile)
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_MODEL=llama-3.3-70b-versatile
# SYNTH_MODEL=openai/gpt-oss-120b

# Optional: use Google Gemini free tier instead of Groq
# LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# LLM_MODEL=gemini-2.5-flash
# LLM_API_KEY=  ← from aistudio.google.com/apikey

# Optional: Jina API key (free and keyless by default — only set if you hit rate limits)
# JINA_API_KEY=

# Set automatically by Vercel — leave blank locally
# NEXT_PUBLIC_SITE_URL=
# VERCEL_URL=
